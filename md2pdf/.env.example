# Environment configuration for md2pdf
# Copy this file to .env and adjust the paths as needed

# Path to wkhtmltopdf executable
# Windows example:
# WKHTMLTOPDF_PATH=C:\Program Files\wkhtmltopdf\bin\wkhtmltopdf.exe
# Linux example:
# WKHTMLTOPDF_PATH=/usr/bin/wkhtmltopdf
# macOS example:
# WKHTMLTOPDF_PATH=/usr/local/bin/wkhtmltopdf

# Directory containing CSS files
# By default, it looks in the same directory as the script
# CSS_DIR=D:\Code\sakura4036\md2pdf\css

# Example settings:
WKHTMLTOPDF_PATH=C:\Program Files\wkhtmltopdf\bin\wkhtmltopdf.exe
CSS_DIR=D:\Code\sakura4036\md2pdf\css
MATHJAX_URL=path/to/MathJax.js